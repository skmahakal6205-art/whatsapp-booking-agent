# ============================================
# WhatsApp Salon Automation System - Config
# ============================================

# Server
PORT=3000
BASE_URL=https://your-domain.com

# ---- WhatsApp API (Choose ONE provider) ----

# Option A: WATI
WHATSAPP_PROVIDER=wati
WATI_API_URL=https://live-server-xxxxx.wati.io
WATI_API_TOKEN=your_wati_api_token

# Option B: Twilio
# WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ---- Google Calendar ----
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_CALENDAR_ID=primary

# ---- Google Gemini / Vertex AI (optional) ----
GOOGLE_PROJECT_ID=your_google_project_id
GOOGLE_API_KEY=your_google_api_key
# Optional: change region or model if needed
GOOGLE_API_LOCATION=us-central1
GOOGLE_MODEL=gemini-1.5-pro

# ---- Bitrix24 CRM ----
BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.com/rest/1/your_webhook_token

# ---- Payment (Razorpay) ----
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ---- Salon Config ----
SALON_NAME=JH BLENZ Salon & Academy
SALON_OWNER_PHONE=+919876543210
SALON_OPEN_TIME=10:00
SALON_CLOSE_TIME=20:00
SALON_SLOT_DURATION_MINS=30
